{
    "_comment": "service 端 - 示例 3 Field。Service=0x3333, Instance=0x0001。Field 是 Get(0x0001)/Set(0x0002)/Notifier(0x8002, eventgroup 0x0002) 的组合。",

    "unicast": "127.0.0.1",
    "logging": { "level": "info", "console": "true", "file": { "enable": "false" }, "dlt": "false" },

    "applications": [ { "name": "service", "id": "0x3001" } ],

    "services": [
        {
            "service":  "0x3333",
            "instance": "0x0001",
            "reliable": { "port": "30503" },
            "events": [
                {
                    "event":      "0x8002",
                    "is_field":   "true",
                    "is_reliable": "true"
                }
            ],
            "eventgroups": [
                { "eventgroup": "0x0002", "events": [ "0x8002" ] }
            ]
        }
    ],

    "routing": "service",
    "service-discovery": {
        "enable":    "true",
        "multicast": "224.244.224.245",
        "port":      "30490",
        "protocol":  "udp"
    }
}
