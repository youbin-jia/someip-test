{
    "_comment": "service 端 - 示例 2 Event。Service=0x2222, Instance=0x0001, Event=0x8001, Eventgroup=0x0001。事件走 UDP (unreliable)。",

    "unicast": "127.0.0.1",
    "logging": { "level": "info", "console": "true", "file": { "enable": "false" }, "dlt": "false" },

    "applications": [ { "name": "service", "id": "0x2001" } ],

    "services": [
        {
            "service":  "0x2222",
            "instance": "0x0001",
            "unreliable": "30502",
            "events": [
                {
                    "event":     "0x8001",
                    "is_field":  "false",
                    "is_reliable": "false",
                    "update-cycle": "1000"
                }
            ],
            "eventgroups": [
                { "eventgroup": "0x0001", "events": [ "0x8001" ] }
            ]
        }
    ],

    "routing": "service",
    "service-discovery": {
        "enable":    "true",
        "multicast": "224.244.224.245",
        "port":      "30490",
        "protocol":  "udp"
    }
}
