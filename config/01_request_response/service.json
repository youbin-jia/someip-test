{
    "_comment": "service 端配置 - 示例 1 Request/Response。Service-ID=0x1111, Instance=0x0001, Method=0x0421(echo)",

    "unicast": "127.0.0.1",
    "logging": {
        "level": "info",
        "console": "true",
        "file":  { "enable": "false" },
        "dlt":   "false"
    },

    "applications": [
        { "name": "service", "id": "0x1001" }
    ],

    "services": [
        {
            "service":    "0x1111",
            "instance":   "0x0001",
            "reliable":   { "port": "30501", "enable-magic-cookies": "false" }
        }
    ],

    "routing": "service",

    "service-discovery": {
        "enable":    "true",
        "multicast": "224.244.224.245",
        "port":      "30490",
        "protocol":  "udp",
        "initial_delay_min": "10",
        "initial_delay_max": "100",
        "repetitions_base_delay": "200",
        "repetitions_max":   "3",
        "ttl":               "3",
        "cyclic_offer_delay": "2000",
        "request_response_delay": { "minimum": "10", "maximum": "100" }
    }
}
